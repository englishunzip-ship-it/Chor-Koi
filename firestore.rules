rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidReport(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 &&
             data.corruptionType is string &&
             data.locationName is string &&
             data.latitude is number &&
             data.longitude is number &&
             data.votesTrue is number &&
             data.votesFalse is number &&
             data.votesNeedEvidence is number;
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if isValidReport(request.resource.data);
      allow update: if (
        // Allow voting (incrementing counters)
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['votesTrue', 'votesFalse', 'votesNeedEvidence'])
      ) || (
        // Allow admin full update
        isAuthenticated()
      );
      allow delete: if isAuthenticated();
    }
    
    match /corruptionTypes/{typeId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
