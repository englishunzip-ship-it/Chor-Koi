{
  "entities": {
    "Report": {
      "title": "Corruption Report",
      "description": "A report of a corruption incident.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the report" },
        "description": { "type": "string", "description": "Detailed description" },
        "corruptionType": { "type": "string", "description": "Type ID of corruption" },
        "locationName": { "type": "string", "description": "Name of the location" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "evidenceLinks": { "type": "array", "items": { "type": "string" } },
        "votesTrue": { "type": "integer" },
        "votesFalse": { "type": "integer" },
        "votesNeedEvidence": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "corruptionType", "locationName", "latitude", "longitude"]
    },
    "CorruptionType": {
      "title": "Corruption Type",
      "description": "Category of corruption.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "icon"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of corruption reports"
    },
    "/corruptionTypes/{typeId}": {
      "schema": "CorruptionType",
      "description": "Categories of corruption"
    }
  }
}
